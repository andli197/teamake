{
  "version": 4,
  "cmakeMinimumRequired": {
    "major": 1,
    "minor": 2,
    "patch": 3
  },
  "configurePresets": [
    {
      "name": "Config",
      "generator": "Ninja",
      "binaryDir": "${sourceParentDir}/build-${sourceDirName}",
      "installDir": "${sourceParentDir}/install-${sourceDirName}"
    }
  ],
  "buildPresets": [
    {
      "name": "Build",
      "configurePreset": "Config",
      "configuration": "Debug"
    }
  ],
  "testPresets": [
    {
      "name": "Test",
      "configurePreset": "Config",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
